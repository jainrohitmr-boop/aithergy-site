---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Contact — Aithergy',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- HERO ********************************************************* -->

  <section class="relative w-full overflow-hidden min-h-[550px] lg:min-h-[650px]">
    <!-- Light abstract energy-flow background -->
    <div 
      class="absolute inset-0 w-full h-full bg-cover bg-center opacity-90"
      style="background-image: url('/images/contact-hero.png');"
    ></div>

    <div class="relative z-10 flex flex-col justify-center h-full px-6 lg:px-12 max-w-3xl">
      <h1 class="text-4xl lg:text-5xl font-semibold tracking-tight mb-6">
        Let’s connect.
      </h1>

      <p class="text-lg text-slate-300 max-w-2xl">
        Whether you're exploring AI strategy, systems design or energy optimisation — I’d love to hear from you.
      </p>
    </div>
  </section>

  <!-- CONTACT DETAILS ********************************************** -->

  <section class="py-20 lg:py-28">
    <div class="container max-w-3xl px-6 lg:px-8">
      <h2 class="text-3xl font-semibold tracking-tight mb-6">Get in touch</h2>

      <p class="text-lg text-slate-600 mb-6">
        The simplest way to reach me is by email. I respond personally to every message.
      </p>

      <div class="bg-white dark:bg-slate-900 shadow rounded-xl p-8 border border-slate-200 dark:border-slate-700">
        <h3 class="text-xl font-semibold mb-3">Email</h3>
        <a 
          href="mailto:info@aithergy.com" 
          class="text-accent font-medium hover:underline"
        >
          info@aithergy.com
        </a>

        <div class="mt-8">
          <h3 class="text-xl font-semibold mb-3">Location</h3>
          <p class="text-slate-600">
            Sevenoaks, Kent, United Kingdom
          </p>
        </div>

        <!-- Optional booking link (future) -->
        <!--
        <div class="mt-8">
          <h3 class="text-xl font-semibold mb-3">Book a call</h3>
          <a 
            href="https://calendly.com/your-link" 
            class="text-accent font-medium hover:underline"
          >
            Schedule a 30‑minute intro call →
          </a>
        </div>
        -->
      </div>
    </div>
  </section>

  <!-- CTA *********************************************************** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Email Me',
        href: 'mailto:info@aithergy.com',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to explore what we can build?
    </Fragment>

    <Fragment slot="subtitle">
      Reach out anytime — I’d be happy to discuss your project, idea or challenge.
    </Fragment>
  </CallToAction>

</Layout>
