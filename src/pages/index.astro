---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Aithergy — AI, Energy Systems & Human Performance',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- AITHERGY HERO ************************************************ -->

  <section class="relative w-full overflow-hidden">
    <!-- Full-width background image -->
    <div 
      class="absolute inset-0 w-full h-full bg-cover bg-center opacity-90"
      style="background-image: url('/images/hero-aithergy.png');"
    ></div>

    <!-- Hero content stays on top -->
    <div class="relative z-10">
      <Hero
        actions={[
          {
            variant: 'primary',
            text: 'Work with Aithergy',
            href: '#contact',
          },
          {
            text: 'Explore Ecosenz',
            href: '/ecosenz',
          },
        ]}
      >
        <div slot="title" class="px-6 lg:px-12">
          Founder‑led innovation at the intersection of
          <span class="text-accent dark:text-white">AI, energy systems</span>
          and human performance.
        </div>

        <div slot="subtitle" class="px-6 lg:px-12">
          Aithergy helps founders and organisations unlock clarity, accelerate innovation, and build systems that scale —
          blending AI‑driven automation, energy‑system thinking, and practical product development experience.
        </div>
      </Hero>
    </div>
  </section>

  <!-- ABOUT AITHERGY ************************************************ -->

  <section class="py-20 lg:py-28">
    <div class="container max-w-3xl px-6 lg:px-8">
      <h2 class="text-3xl font-semibold tracking-tight mb-6">About Aithergy</h2>

      <p class="text-lg text-slate-600 mb-4">
        Aithergy is an independent innovation studio led by Rohit Jain, focused on the intersection of AI, energy
        systems and human performance. I work with founders and teams who want to move beyond experimentation and build
        systems that actually ship, scale and evolve.
      </p>

      <p class="text-lg text-slate-600">
        My background spans renewable energy, e‑Fuels, hydrogen systems and applied AI — from offshore wind projects and
        green methanol concepts to AI‑driven workflow design and product delivery. Aithergy is where that experience
        converges into something practical, modern and execution‑focused.
      </p>
    </div>
  </section>

  <!-- WHAT AITHERGY DOES ******************************************** -->

  <section class="py-20 lg:py-28 bg-blue-50/40 dark:bg-transparent">
    <div class="container max-w-5xl px-6 lg:px-8">
      <h2 class="text-3xl font-semibold tracking-tight mb-10">What Aithergy Does</h2>

      <div class="grid gap-10 md:grid-cols-3">

        <div>
          <h3 class="text-xl font-semibold mb-3">AI Strategy & Automation</h3>
          <p class="text-slate-600">
            I help teams embed practical AI systems that streamline workflows, accelerate delivery, and unlock new
            capabilities — including partner‑AI integration, workflow automation, rapid prototyping, and intelligent
            tooling.
          </p>
        </div>

        <div>
          <h3 class="text-xl font-semibold mb-3">Innovation & Systems Thinking</h3>
          <p class="text-slate-600">
            Using principles from energy networks, flow optimisation and complex system design, I help organisations
            build scalable, resilient processes that reduce bottlenecks and increase throughput.
          </p>
        </div>

        <div>
          <h3 class="text-xl font-semibold mb-3">Product & Technology Advisory</h3>
          <p class="text-slate-600">
            I work with founders to define product strategy, build early prototypes, and establish delivery frameworks
            that support rapid iteration and measurable outcomes.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- INNOVATION & ENERGY SYSTEMS *********************************** -->

  <section class="py-20 lg:py-28">
    <div class="container max-w-4xl px-6 lg:px-8">
      <h2 class="text-3xl font-semibold tracking-tight mb-6">Innovation & Energy Systems</h2>

      <p class="text-lg text-slate-600 mb-4">
        Aithergy’s roots lie in renewable energy and e‑Fuels. My past work includes green methanol project development,
        biomethane production using biological methanation, hydrogen‑based synthesis pathways, and CO₂‑to‑methanol
        conversion technologies.
      </p>

      <p class="text-lg text-slate-600 mb-4">
        This experience shapes how I approach AI and innovation today: through the lens of flows, constraints,
        efficiency and system‑level optimisation — applying similar thinking to digital workflows, product development
        and organisational design.
      </p>
    </div>
  </section>

  <!-- ECOSENZ TEASER ************************************************ -->

  <section class="py-20 lg:py-28 bg-blue-50/40 dark:bg-transparent">
    <div class="container max-w-3xl px-6 lg:px-8">
      <h2 class="text-3xl font-semibold tracking-tight mb-6">Ecosenz — Wellness Division</h2>

      <p class="text-lg text-slate-600 mb-4">
        Aithergy’s wellness division focuses on functional powders, personalised nutrition, and AI‑guided wellness
        systems — combining ancient principles with modern science.
      </p>

      <a href="/ecosenz" class="text-accent font-semibold hover:underline">
        Explore Ecosenz →
      </a>
    </div>
  </section>

  <!-- CALL TO ACTION ************************************************ -->

  <CallToAction
    id="contact"
    actions={[
      {
        variant: 'primary',
        text: 'Work with Aithergy',
        href: 'mailto:contact@aithergy.com',
      },
    ]}
  >
    <Fragment slot="title">
      Build with clarity.<br class="block sm:hidden" /> Build with Aithergy.
    </Fragment>

    <Fragment slot="subtitle">
      If you're exploring AI, systems thinking or wellness innovation, Aithergy helps you move from idea to execution
      with speed and precision.
    </Fragment>
  </CallToAction>

</Layout>
