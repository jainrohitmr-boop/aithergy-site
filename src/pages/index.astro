---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { METADATA } from 'astrowind:config';

const metadata = {
  ...METADATA,
  title: 'Aithergy — Strategic Intelligence',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- HERO ********************************************************* -->

  <section class="relative w-full overflow-hidden min-h-[550px] lg:min-h-[600px]">
    <div 
      class="absolute inset-0 w-full h-full bg-cover bg-center opacity-90"
      style="background-image: url('/images/hero-aithergy.png');"
    ></div>

    <div class="relative z-10 flex flex-col justify-center h-full px-6 lg:px-8 max-w-4xl pt-20">
      <h1 class="text-4xl lg:text-5xl font-semibold tracking-tight mb-6">
        Strategic intelligence for founders and energy innovators.
      </h1>

      <p class="text-lg text-slate-600 max-w-2xl mb-8">
        Aithergy blends AI strategy, systems thinking and optimisation to help leaders build clarity, momentum 
        and intelligent solutions — from founder workflows to large‑scale energy systems.
      </p>

      <a 
        href="/work-with-me"
        class="inline-block bg-accent text-white font-semibold px-6 py-3 rounded-lg shadow hover:opacity-90 transition"
      >
        Work With Me
      </a>
    </div>
  </section>

  <!-- WHAT WE DO *************************************************** -->

  <section class="py-20 lg:py-28">
    <div class="container max-w-5xl px-6 lg:px-8">
      <h2 class="text-3xl font-semibold tracking-tight mb-10">What we do</h2>

      <div class="grid gap-10 md:grid-cols-2">

        <div>
          <h3 class="text-xl font-semibold mb-3">AI Strategy & Systems Thinking</h3>
          <p class="text-slate-600">
            Helping founders and operators design intelligent workflows, decision systems and operating structures 
            that reduce friction and increase clarity.
          </p>
          <a href="/work-with-me" class="text-accent font-medium mt-3 inline-block hover:underline">
            Learn more →
          </a>
        </div>

        <div>
          <h3 class="text-xl font-semibold mb-3">Energy Systems Optimisation</h3>
          <p class="text-slate-600">
            Using AI‑based optimisation to reduce curtailment, improve utilisation and unlock new value from 
            renewable energy systems.
          </p>
          <a href="/energy-systems" class="text-accent font-medium mt-3 inline-block hover:underline">
            Learn more →
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- HOW WE THINK ************************************************* -->

  <section class="py-20 lg:py-28 bg-blue-50/40 dark:bg-transparent">
    <div class="container max-w-4xl px-6 lg:px-8">
      <h2 class="text-3xl font-semibold tracking-tight mb-6">How we think</h2>

      <p class="text-lg text-slate-600 mb-4">
        Aithergy is built on the belief that clarity, structure and intelligent systems create better outcomes — 
        in business, in energy and in human performance.
      </p>

      <ul class="list-disc pl-6 text-slate-600 space-y-2 mt-4">
        <li>Clarity beats complexity</li>
        <li>Systems create outcomes</li>
        <li>AI is a multiplier, not a replacement</li>
        <li>Energy — human and renewable — must flow intelligently</li>
      </ul>
    </div>
  </section>

  <!-- ECOSENZ MENTION ********************************************** -->

  <section class="py-20 lg:py-28">
    <div class="container max-w-4xl px-6 lg:px-8">
      <h2 class="text-3xl font-semibold tracking-tight mb-6">Aithergy in wellness</h2>

      <p class="text-lg text-slate-600 mb-4">
        Aithergy also powers <strong>Ecosenz</strong> — an AI‑driven wellness system designed to help individuals 
        improve clarity, energy and balance through personalised routines and intelligent insights.
      </p>

      <a href="/ecosenz" class="text-accent font-medium hover:underline">
        Explore Ecosenz →
      </a>
    </div>
  </section>

  <!-- CTA *********************************************************** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get in touch',
        href: 'mailto:info@aithergy.com',
      },
    ]}
  >
    <Fragment slot="title">
      Let’s build intelligently.
    </Fragment>

    <Fragment slot="subtitle">
      If you’re exploring AI, systems design or energy optimisation — I’d love to hear from you.
    </Fragment>
  </CallToAction>

</Layout>

